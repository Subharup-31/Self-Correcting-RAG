# ============================================================
# Ultimate-RAG Environment Variables
# Copy this file to .env and fill in your keys
# ============================================================

# --- LLM Provider (choose one) ---
GOOGLE_API_KEY=your_gemini_api_key_here          # Gemini 3.5 Flash / Lite (recommended, free tier)
# OPENAI_API_KEY=your_openai_key_here            # GPT-4o-mini (alternative)
# NVIDIA_API_KEY=your_nvidia_api_key_here        # NVIDIA NIM API key (build.nvidia.com)
# OPENROUTER_API_KEY=your_openrouter_api_key_here # OpenRouter API key (openrouter.ai)

# --- Web Search (optional but highly recommended) ---
TAVILY_API_KEY=your_tavily_api_key_here

# --- LangSmith Tracing (optional, for debugging) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key
# LANGCHAIN_PROJECT=ultimate-rag

# --- Configuration ---
LLM_PROVIDER=gemini                              # "gemini" | "openai" | "nvidia"
LLM_MODEL=gemini-3.5-flash-lite                  # Model name
EMBEDDING_PROVIDER=huggingface                  # "huggingface" | "google" | "openai" | "nvidia"
EMBEDDING_MODEL=BAAI/bge-m3                     # Model name (e.g. nvidia/nv-embedqa-e5-v5 or gemini-embedding-2)
RERANKER_PROVIDER=huggingface                  # "huggingface" | "nvidia" | "openrouter" | "none"
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2 # Model name (e.g. nvidia/llama-nemotron-rerank-vl-1b-v2 or nvidia/llama-3.2-nv-rerankqa-1b-v2)
CHROMA_PERSIST_DIR=./chroma_db                  # ChromaDB storage path
LOG_LEVEL=INFO
CONFIDENCE_THRESHOLD=0.5                        # Below this → low-confidence flag
MAX_RETRY_COUNT=3                               # Max re-query iterations
